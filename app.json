{
  "expo": {
    "name": "Mutual",
    "slug": "instagram-tracker",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "description": "Mutual — see who's really with you. Privacy-first Instagram follower tracker. 100% local, no login, no tracking.",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#E1306C"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.nuhaadh.mutual",
      "infoPlist": {
        "LSApplicationQueriesSchemes": ["instagram"],
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": false
        }
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#E1306C"
      },
      "package": "com.nuhaadh.mutual",
      "predictiveBackGestureEnabled": false,
      "blockedPermissions": ["android.permission.INTERNET"]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "your-project-id"
      }
    },
    "plugins": [
      "expo-sharing",
      "expo-font"
    ]
  }
}
